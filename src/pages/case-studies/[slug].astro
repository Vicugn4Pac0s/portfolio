---
import { render } from 'astro:content';
import PageIntro from '../../components/ui/PageIntro.astro';
import SiteFooter from '../../components/ui/SiteFooter.astro';
import SiteHeader from '../../components/ui/SiteHeader.astro';
import SubpageContent from '../../components/ui/SubpageContent.astro';
import { getCaseStudyStaticPaths } from '../../data/caseStudies';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return getCaseStudyStaticPaths();
}

const { study } = Astro.props;
const { Content } = await render(study);
const { title, description, period, role, tags, image } = study.data;
---

<BaseLayout title={`${title} | Case Study`} description={description}>
  <SiteHeader />
  <SubpageContent>
    <section class="cs-detail site-container">
      <PageIntro title={title} description={description} />

      <div class="cs-summary">
        <figure class="cs-summary__hero">
          <img
            class="cs-summary__hero-image"
            src={image}
            alt={`${title} - プロジェクトイメージ`}
            loading="eager"
          />
        </figure>

        <aside class="cs-summary__meta">
          <dl class="cs-summary__info">
            <div class="cs-summary__info-item">
              <dt class="cs-summary__info-label">期間</dt>
              <dd class="cs-summary__info-value">{period}</dd>
            </div>
            <div class="cs-summary__info-item">
              <dt class="cs-summary__info-label">役割</dt>
              <dd class="cs-summary__info-value">{role}</dd>
            </div>
            <div class="cs-summary__info-item">
              <dt class="cs-summary__info-label">技術スタック</dt>
              <dd class="cs-summary__info-value">
                <ul class="cs-summary__stack">
                  {tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </dd>
            </div>
          </dl>
        </aside>
      </div>

      <div class="cs-article">
        <Content />
      </div>
    </section>
  </SubpageContent>
  <SiteFooter />
</BaseLayout>

<style lang="scss">
  @use '@styles/global' as *;
  .cs-detail {
    min-width: 0;
  }

  .cs-summary {
    display: flex;
    gap: 4rem;
    margin-bottom: 6rem;

    @include media-tab {
      flex-direction: column;
      gap: 32px;
    }

    @include media-sp {
      flex-direction: column;
      gap: 24px;
      margin-bottom: 4rem;
    }

    &__hero {
      flex: 1;
      overflow: hidden;
    }

    &__hero-image {
      display: block;
      width: 100%;
      height: 100%;
      min-height: 340px;
      object-fit: cover;

      @include media-tab {
        height: clamp(240px, 50vw, 400px);
      }
    }

    &__meta {
      flex: 1;
      min-width: 0;
      display: flex;
      flex-direction: column;
    }

    &__info {
      flex: 1;
    }

    &__info-item {
      padding: 1.6rem 0;

      & + & {
        border-top: 1px solid var(--color-line);
      }

      &:first-child {
        padding-top: 0;
      }

      &:last-child {
        padding-bottom: 0;
      }
    }

    &__info-label {
      display: block;
      margin-bottom: 6px;
      color: var(--color-blue);
      font-size: 1.2rem;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    &__info-value {
      margin: 0;
      color: var(--color-ink);
      font-size: 1.4rem;
      font-weight: 650;
      line-height: 1.8;
    }

    &__stack {
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
      margin: 0;
      padding: 0;
      list-style: none;
    }
  }

  .cs-article {
    min-width: 0;

    :global(h2) {
      font-size: 2.4rem;
      font-weight: 800;
      margin: 5.6rem 0 1.6rem;

      @include media-sp {
        font-size: 1.8rem;
        margin: 4rem 0 1.4rem;
      }
    }

    :global(h3) {
      font-size: 1.8rem;
      font-weight: 800;
      margin: 4rem 0 1.4rem;

      @include media-sp {
        font-size: 1.6rem;
        margin: 3rem 0 1.2rem;
      }
    }

    :global(p),
    :global(li) {
      color: var(--color-muted);
      font-size: 1.6rem;

      @include media-sp {
        font-size: 1.4rem;
      }
    }

    :global(strong) {
      color: var(--color-ink);
    }
  }
</style>
