---
import { render } from 'astro:content';
import PageIntro from '../../components/ui/PageIntro.astro';
import SiteFooter from '../../components/ui/SiteFooter.astro';
import SiteHeader from '../../components/ui/SiteHeader.astro';
import { getCaseStudyStaticPaths } from '../../data/caseStudies';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  return getCaseStudyStaticPaths();
}

const { study } = Astro.props;
const { Content } = await render(study);
const { title, description, period, role, tags, image } = study.data;
---

<BaseLayout title={`${title} | Case Study`} description={description}>
  <SiteHeader />
  <main class="cs-detail">
    <div class="site-container">
      <PageIntro title={title} description={description} variant="wide" />

      <figure class="cs-detail__hero">
        <img
          class="cs-detail__hero-image"
          src={image}
          alt={`${title} - プロジェクトイメージ`}
          loading="eager"
        />
      </figure>

      <div class="cs-detail__body">
        <aside class="cs-detail__sidebar">
          <dl class="cs-detail__info">
            <div class="cs-detail__info-item">
              <dt class="cs-detail__info-label">期間</dt>
              <dd class="cs-detail__info-value">{period}</dd>
            </div>
            <div class="cs-detail__info-item">
              <dt class="cs-detail__info-label">役割</dt>
              <dd class="cs-detail__info-value">{role}</dd>
            </div>
            <div class="cs-detail__info-item">
              <dt class="cs-detail__info-label">技術スタック</dt>
              <dd class="cs-detail__info-value">
                <ul class="cs-detail__stack">
                  {tags.map((tag) => <li>{tag}</li>)}
                </ul>
              </dd>
            </div>
          </dl>
        </aside>

        <div class="cs-detail__content">
          <Content />
        </div>
      </div>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>

<style lang="scss">
  .cs-detail {
    padding: 60px 0 120px;

    &__tag {
      padding: 4px 12px;
      border: 1px solid var(--color-line);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.8);
      color: var(--color-muted);
      font-size: 11px;
      font-weight: 800;
    }

    &__hero {
      margin: 0 0 56px;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      overflow: hidden;
      box-shadow: var(--shadow-soft);
    }

    &__hero-image {
      display: block;
      width: 100%;
      height: clamp(280px, 40vw, 520px);
      object-fit: cover;
    }

    &__body {
      display: grid;
      grid-template-columns: 220px 1fr;
      gap: 56px;
      align-items: start;
    }

    &__sidebar {
      position: sticky;
      top: 80px;
    }

    &__info {
      margin: 0;
      padding: 28px 24px;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.8);
      box-shadow: var(--shadow-soft);
    }

    &__info-item {
      padding: 16px 0;

      & + & {
        border-top: 1px solid var(--color-line);
      }

      &:first-child {
        padding-top: 0;
      }

      &:last-child {
        padding-bottom: 0;
      }
    }

    &__info-label {
      display: block;
      margin-bottom: 6px;
      color: var(--color-blue);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    &__info-value {
      margin: 0;
      color: var(--color-ink);
      font-size: 13px;
      font-weight: 650;
      line-height: 1.8;
    }

    &__stack {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin: 0;
      padding: 0;
      list-style: none;
    }

    &__content {
      min-width: 0;

      :global(h2) {
        margin: 56px 0 16px;
        font-size: 24px;
        font-weight: 800;
      }

      :global(h3) {
        margin: 40px 0 14px;
        font-size: 18px;
        font-weight: 800;
      }

      :global(p),
      :global(li) {
        color: var(--color-muted);
        font-size: 15px;
        font-weight: 650;
        line-height: 2;
      }

      :global(ul),
      :global(ol) {
        padding-left: 1.4em;
      }

      :global(strong) {
        color: var(--color-ink);
      }
    }
  }

  @media (max-width: 1023px) {
    .cs-detail {
      &__body {
        grid-template-columns: 1fr;
        gap: 32px;
      }

      &__sidebar {
        position: static;
      }
    }
  }

  @media (max-width: 767px) {
    .cs-detail {
      padding: 40px 0 96px;

      &__hero {
        margin-bottom: 40px;
      }

      &__info {
        padding: 24px 20px;
      }
    }
  }
</style>
