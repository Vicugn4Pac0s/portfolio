---
import CaseStudyList from '../../components/ui/CaseStudyList.astro';
import PageIntro from '../../components/ui/PageIntro.astro';
import SubpageContent from '../../components/ui/SubpageContent.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/ui/SiteFooter.astro';
import SiteHeader from '../../components/ui/SiteHeader.astro';
import { getCaseStudySummaries } from '../../data/caseStudies';

const studies = await getCaseStudySummaries();
---

<BaseLayout
  title="Case Studies | yoshiki.rundev"
  description="フロントエンドエンジニアとしての実績・ケーススタディ一覧です。"
>
  <SiteHeader />
  <SubpageContent>
    <section class="cs-index site-container">
      <PageIntro
        title="実績・ケーススタディ"
        description="フロントエンドエンジニアとして担当したプロジェクトの設計・実装・成果をまとめています。"
      />
      <CaseStudyList studies={studies} />
    </section>
  </SubpageContent>
  <SiteFooter />
</BaseLayout>
