---
import AboutSection from '../components/section/AboutSection.astro';
import CaseStudiesSection from '../components/section/CaseStudiesSection.astro';
import ContactSection from '../components/section/ContactSection.astro';
import HeroSection from '../components/section/HeroSection.astro';
import HistorySection from '../components/section/HistorySection.astro';
import PersonalSection from '../components/section/PersonalSection.astro';
import SiteFooter from '../components/ui/SiteFooter.astro';
import SiteHeader from '../components/ui/SiteHeader.astro';
import StrengthsSection from '../components/section/StrengthsSection.astro';
import { getCaseStudySummaries } from '../data/caseStudies';
import { histories, strengths } from '../data/portfolio';
import BaseLayout from '../layouts/BaseLayout.astro';

const studies = await getCaseStudySummaries();
---

<BaseLayout title="yoshiki.rundev | Frontend Engineer" description="保守性の高いシステム設計とプロダクト思考で、長く価値を生むフロントエンド開発を行うポートフォリオです。">
  <SiteHeader variant="overlay" />
  <main>
    <HeroSection />
    <AboutSection />
    <StrengthsSection strengths={strengths} />
    <HistorySection histories={histories} />
    <CaseStudiesSection studies={studies} />
    <PersonalSection />
    <ContactSection />
  </main>
  <SiteFooter />
</BaseLayout>
