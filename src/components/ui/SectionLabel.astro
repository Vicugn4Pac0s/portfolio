---
interface Props {
  label: string;
  align?: 'left' | 'between';
}

const { label, align = 'left' } = Astro.props;
---

<div class:list={['section-label', align === 'between' && 'section-label--between']}>
  <span class="section-label__text">{label}</span>
  <slot />
</div>

<style lang="scss">
  .section-label {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 24px;
    margin-bottom: 34px;
    color: var(--color-primary);
    font-size: 2.4rem;
    font-style: italic;
    font-weight: 600;
    letter-spacing: 0.04em;
    position: relative;

    &--between {
      justify-content: space-between;
    }

    &__text {
      display: inline-block;
    }

    &::after {
      content: '';
      background-color: var(--color-accent);
      display: block;
      height: 3px;
      width: 7.2rem;
      position: absolute;
      top: 50%;
      left: 100%;
      transform: translate(1.2rem, -50%) skewX(-45deg);
    }
  }

  @media (max-width: 767px) {
    .section-label {
      &--between {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
      }
    }
  }
</style>
