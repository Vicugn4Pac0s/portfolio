---
interface Props {
  label: string;
  align?: 'left' | 'between';
}

const { label, align = 'left' } = Astro.props;
---

<div class:list={['section-label', align === 'between' && 'section-label--between']}>
  <span class="section-label__text">{label}</span>
  <slot />
</div>

<style lang="scss">
  .section-label {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 24px;
    margin-bottom: 34px;
    color: var(--color-primary);
    font-size: 2.4rem;
    font-weight: 800;
    letter-spacing: 0.04em;

    &--between {
      justify-content: space-between;
    }

    &__text {
      display: inline-block;
    }
  }

  @media (max-width: 767px) {
    .section-label {
      &--between {
        align-items: flex-start;
        flex-direction: column;
        gap: 12px;
      }
    }
  }
</style>
