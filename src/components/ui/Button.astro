---
interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  type = 'button',
  class: className,
  target,
  rel,
  ...attrs
} = Astro.props;
---

{
  href ? (
    <a
      class:list={['button', className]}
      href={href}
      target={target}
      rel={rel}
      {...attrs}
    >
      <span class="button__label"><slot /></span>
      <span class="button__icon" aria-hidden="true">›</span>
    </a>
  ) : (
    <button class:list={['button', className]} type={type} {...attrs}>
      <span class="button__label"><slot /></span>
      <span class="button__icon" aria-hidden="true">›</span>
    </button>
  )
}

<style lang="scss">
  @use '@styles/global' as *;
  
  .button {
    position: relative;
    display: inline-flex;
    min-width: 292px;
    align-items: center;
    justify-content: center;
    padding: 0 4rem 0 2.4rem;
    background: var(--color-base-white);
    border: 1px solid var(--color-primary);
    color: var(--color-primary);
    font-size: 1.6rem;
    font-weight: 700;
    line-height: 5.6rem;
    transition:
      background 160ms ease,
      color 160ms ease;

    &:hover {
      background: var(--color-primary);
      color: var(--color-base-white);
    }

    &__label {
      display: inline-flex;
      align-items: center;
    }

    &__icon {
      position: absolute;
      top: 50%;
      right: 1.6rem;
      width: 0.8em;
      overflow: hidden;
      font-size: 16px;
      font-weight: 400;
      line-height: 0.8;
      transform: translateY(calc(-50% - 1px));
    }

    @include media-sp {
      min-width: min(100%, 292px);
    }
  }
</style>
