---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<header class="page-intro">
  <div class="page-intro__content">
    <h1 class="page-intro__title">{title}</h1>
    <p class="page-intro__description">{description}</p>
  </div>
</header>

<style lang="scss">
  @use '@styles/global' as *;

  .page-intro {
    &__content {
      padding: 5.6rem 0;

      @include media-sp {
        padding: 3.2rem 0;
      }
    }

    &__title {
      font-size: 2.4rem;
      font-weight: bold;
      margin-bottom: 1.6rem;

      @include media-sp {
        font-size: 2rem;
      }
    }

    &__description {
      margin: 0;
      color: var(--color-muted);
      font-size: 1.4rem;
    }
  }
</style>
