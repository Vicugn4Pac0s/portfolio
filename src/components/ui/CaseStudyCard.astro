---
interface Props {
  slug: string;
  title: string;
  description: string;
  image: string;
}

const { slug, title, description, image } = Astro.props;
---

<article class="case-study-card">
  <a href={`/case-studies/${slug}`}>
    <div class="case-study-card__visual">
      <img
        class="case-study-card__image"
        src={image}
        alt={`${title} preview`}
        loading="lazy"
      />
    </div>
    <div class="case-study-card__body">
      <h3 class="case-study-card__title">{title}</h3>
      <p class="case-study-card__text">{description}</p>
    </div>
  </a>
</article>

<style lang="scss">
  @use '@styles/global' as *;
  .case-study-card {

    height: 100%;
    overflow: hidden;
    background: var(--color-base-white);
    > a {
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    &__visual {
      position: relative;
      aspect-ratio: 16 / 9;
      overflow: hidden;

      &::before {
        position: absolute;
        top: 50%;
        left: -60%;
        z-index: 1;
        width: 36%;
        height: 240%;
        background: var(--color-primary);
        opacity: 1;
        content: '';
        pointer-events: none;
        transform: translateY(-50%) rotate(45deg);
      }
    }

    &__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    &__body {
      position: relative;
      flex: 1;
      padding: 2.8rem 2rem;
      background-color: var(--color-base-white);
      overflow: hidden;

      &::before {
        position: absolute;
        top: 50%;
        right: -18%;
        width: 18%;
        height: 180%;
        background: var(--color-accent);
        opacity: 0.2;
        content: '';
        pointer-events: none;
        transform: translateY(-50%) rotate(45deg);
      }
    }

    &__title {
      position: relative;
      z-index: 1;
      margin: 0 0 2rem;
      font-size: 2.0rem;
      font-weight: 800;
      @include media-sp {
        font-size: 1.6rem;
        margin-bottom: 1.6rem;
      }
    }

    &__text {
      position: relative;
      z-index: 1;
      min-height: 6.4rem;
      margin: 0;
      color: var(--color-muted);
      font-size: 1.2rem;
      line-height: 2;
    }
  }

</style>
