---
import SectionLabel from './SectionLabel.astro';
---

<section id="contact" class="contact section-block section-block--bordered">
  <div class="site-container">
    <SectionLabel label="CONTACT" />
    <div class="contact__grid">
      <h2 class="section-title">
        ご連絡は下記フォームより<br />
        お気軽にどうぞ。
      </h2>
      <div class="contact__action">
        <a class="contact__button" href="mailto:hello@example.com">
          Open Contact Form
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  .contact {
    &__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      align-items: center;
      gap: 40px;
    }

    &__action {
      display: flex;
      justify-content: flex-end;
    }

    &__button {
      display: inline-flex;
      min-width: 292px;
      align-items: center;
      justify-content: center;
      gap: 22px;
      border: 1px solid var(--color-blue);
      border-radius: 6px;
      color: var(--color-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 54px;
      transition:
        background 160ms ease,
        color 160ms ease;

      &:hover {
        background: var(--color-blue);
        color: white;
      }
    }
  }

  @media (max-width: 767px) {
    .contact {
      &__grid {
        grid-template-columns: 1fr;
      }

      &__action {
        justify-content: flex-start;
      }

      &__button {
        min-width: min(100%, 292px);
      }
    }
  }
</style>
