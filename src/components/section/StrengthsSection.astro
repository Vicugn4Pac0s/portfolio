---
import SectionHeading from '../ui/SectionHeading.astro';

interface Strength {
  title: string;
  icon: string;
  text: string;
}

interface Props {
  strengths: Strength[];
}

const { strengths } = Astro.props;
---

<section id="strengths" class="strengths section-block">
  <div class="site-container">
    <SectionHeading>STRENGTHS</SectionHeading>
    <div class="strengths__list">
      {strengths.map((strength, i) => (
        <article class="strengths__item">
          <span class="strengths__number">{String(i + 1).padStart(2, '0')}</span>
          <div class="strengths__body">
            <h3 class="strengths__title">{strength.title}</h3>
            <p class="strengths__text">{strength.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @use '@styles/global' as *;

  .strengths {
    &__list {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 2.4rem;

      @include media-tab {
        grid-template-columns: repeat(2, 1fr);
      }

      @include media-sp {
        grid-template-columns: 1fr;
      }
    }

    &__item {
      background: var(--color-base-white);
      display: flex;
      align-items: flex-start;
      gap: 1.6rem;
      padding: 1.6rem 0;

      // 上段: 3つ（6列 ÷ 2列ずつ）
      &:nth-child(-n+3) {
        grid-column: span 2;
      }

      // 下段: 2つ（6列 ÷ 3列ずつ）
      &:nth-child(n+4) {
        grid-column: span 3;
      }

      @include media-tab {
        &:nth-child(-n+3),
        &:nth-child(n+4) {
          grid-column: auto;
        }
      }

      @include media-sp {
        padding: 0;

        &:nth-child(-n+3),
        &:nth-child(n+4) {
          grid-column: auto;
        }

      }
    }

    &__number {
      flex-shrink: 0;
      font-size: 4rem;
      font-weight: 900;
      font-style: italic;
      padding-right: 1.6rem;
      line-height: 1;
      color: #ddd;
      position: relative;

      @include media-sp {
        font-size: 3.2rem;
      }

      &::after {
        content: '';
        position: absolute;
        top: 75%;
        right: 0;
        width: 2px;
        height: 100%;
        background-color: var(--color-accent);
        transform: rotate(45deg);
        transform-origin: top right;
      }
    }

    &__body {
      flex: 1;
    }

    &__title {
      font-size: 2.0rem;
      font-weight: bold;
      margin: 0 0 1.6rem;
      @include media-sp {
        font-size: 1.6rem;
      }
    }

    &__text {
      margin: 0;
      font-size: 1.2rem;
    }
  }
</style>
