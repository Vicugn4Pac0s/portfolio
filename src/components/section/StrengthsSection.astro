---
import SectionHeading from '../ui/SectionHeading.astro';

interface Strength {
  title: string;
  icon: string;
  text: string;
}

interface Props {
  strengths: Strength[];
}

const { strengths } = Astro.props;
---

<section id="strengths" class="strengths section-block">
  <div class="site-container">
    <SectionHeading>STRENGTHS</SectionHeading>
    <div class="strengths__list">
      {strengths.map((strength) => (
        <article class="strengths__item">
          <div class="strengths__icon" aria-hidden="true" set:html={strength.icon} />
          <div class="strengths__body">
            <h3 class="strengths__title">{strength.title}</h3>
            <p class="strengths__text">{strength.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .strengths {
    &__list {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
    }

    &__item {
      background: var(--color-base-white);
      display: flex;
      align-items: flex-start;
      gap: 24px;
      padding: 36px 40px;

      // 上段: 2つ（6列 ÷ 3列ずつ）
      &:nth-child(-n+2) {
        grid-column: span 3;
      }

      // 下段: 3つ（6列 ÷ 2列ずつ）
      &:nth-child(n+3) {
        grid-column: span 2;
      }

    }

    &__icon {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 48px;
      height: 48px;
      margin: 4px 0 0;
      color: var(--color-blue);

      :global(svg) {
        width: 48px;
        height: 48px;
      }
    }

    &__body {
      flex: 1;
    }

    &__title {
      margin: 0 0 12px;
      font-size: 14px;
      font-weight: 800;
    }

    &__text {
      margin: 0;
      color: var(--color-muted);
      font-size: 12px;
      font-weight: 650;
      line-height: 1.9;
    }
  }

  @media (max-width: 767px) {
    .strengths {
      &__list {
        grid-template-columns: 1fr;
      }

      &__item {
        grid-column: auto;
        padding: 28px 0;
      }
    }
  }
</style>
