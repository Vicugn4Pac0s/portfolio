---
import SectionLabel from '../ui/SectionLabel.astro';

interface Study {
  slug: string;
  title: string;
  description: string;
  image: string;
}

interface Props {
  studies: Study[];
}

const { studies } = Astro.props;
---

<section id="case-studies" class="case-studies section-block section-block--grey">
  <div class="site-container">
    <SectionLabel label="FEATURED CASE STUDIES" align="between">
      <a class="case-studies__all-link" href="/case-studies">
        View all Case Studies
        <span aria-hidden="true">→</span>
      </a>
    </SectionLabel>
    <div class="case-studies__list">
      {studies.map((study) => (
        <article class="case-studies__card">
          <div class="case-studies__visual">
            <img
              class="case-studies__image"
              src={study.image}
              alt={`${study.title} preview`}
              loading="lazy"
            />
          </div>
          <div class="case-studies__body">
            <h3 class="case-studies__title">{study.title}</h3>
            <p class="case-studies__text">{study.description}</p>
            <a class="case-studies__link" href={`/case-studies/${study.slug}`}>View Case Study <span aria-hidden="true">→</span></a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .case-studies {
    &__all-link,
    &__link {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      color: var(--color-blue);
      font-size: 13px;
      font-weight: 800;
    }

    &__list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    &__card {
      overflow: hidden;
      background: var(--color-base-white);
    }

    &__visual {
      position: relative;
      height: 250px;
      overflow: hidden;
      background: #e2e8f0;
    }

    &__image {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    
    &__body {
      padding: 26px 24px 28px;
    }

    &__title {
      margin: 0 0 20px;
      font-size: 18px;
      font-weight: 800;
    }

    &__text {
      min-height: 62px;
      margin: 0;
      color: var(--color-muted);
      font-size: 13px;
      font-weight: 650;
      line-height: 2;
    }

    &__link {
      margin-top: 24px;
    }
  }

  @media (max-width: 1023px) {
    .case-studies {
      &__list {
        grid-template-columns: 1fr;
      }
    }
  }

  @media (max-width: 767px) {
    .case-studies {
      &__visual {
        height: 220px;
      }
    }
  }
</style>
