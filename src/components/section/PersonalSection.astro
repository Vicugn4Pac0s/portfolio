---
import SectionLabel from '../ui/SectionLabel.astro';

const cards = [
  {
    title: 'Running',
    text: 'ランニング・マラソンを継続。継続改善・長期視点・自己管理を大切にしています。',
    image: 'https://images.unsplash.com/photo-1502224562085-639556652f33?auto=format&fit=crop&w=1000&q=80',
  },
  {
    title: 'Strength Training',
    text: '筋トレを通じて、小さな積み上げの重要性を実感。日々の積み重ねを大切にしています。',
    image: 'https://images.unsplash.com/photo-1598632640487-6ea4a4e8b963?auto=format&fit=crop&w=1000&q=80',
  },
];
---

<section id="personal" class="personal section-block">
  <div class="site-container">
    <SectionLabel label="PERSONAL" />
    <div class="personal__list">
      {cards.map((card) => (
        <article class="personal__card">
          <div class="personal__body">
            <h3 class="personal__title">{card.title}</h3>
            <p class="personal__text">{card.text}</p>
          </div>
          <div class="personal__visual">
            <img class="personal__image" src={card.image} alt={card.title} loading="lazy" />
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  .personal {
    &__list {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    &__card {
      display: flex;
      overflow: hidden;
      border: 1px solid var(--color-line);
      border-radius: 8px;
      background: rgba(255, 255, 255, 0.8);
      box-shadow: var(--shadow-soft);
    }

    &__body {
      flex: 1;
      padding: 36px 28px;
    }

    &__title {
      margin: 0 0 16px;
      font-size: 18px;
      font-weight: 800;
    }

    &__text {
      margin: 0;
      color: var(--color-muted);
      font-size: 14px;
      font-weight: 650;
      line-height: 2.0;
    }

    &__visual {
      flex-shrink: 0;
      width: 160px;
      overflow: hidden;
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  @media (max-width: 767px) {
    .personal {
      &__list {
        grid-template-columns: 1fr;
      }

      &__card {
        flex-direction: column;
      }

      &__visual {
        width: 100%;
        height: 180px;
        order: -1;
      }
    }
  }
</style>
