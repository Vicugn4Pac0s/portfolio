---
import SectionLabel from '../ui/SectionLabel.astro';
---

<section id="contact" class="contact section-block section-block--bordered">
  <div class="site-container">
    <SectionLabel label="CONTACT" />
    <h2 class="section-title">
      ご連絡は下記フォームよりお気軽にどうぞ。
    </h2>
    <div class="contact__action">
      <a class="contact__button" href="mailto:hello@example.com">
        Open Contact Form
        <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

<style lang="scss">
  .contact {
    &__action {
    }

    &__button {
      display: inline-flex;
      min-width: 292px;
      align-items: center;
      justify-content: center;
      gap: 22px;
      border: 1px solid var(--color-blue);
      border-radius: 6px;
      color: var(--color-blue);
      font-size: 16px;
      font-weight: 700;
      line-height: 54px;
      transition:
        background 160ms ease,
        color 160ms ease;

      &:hover {
        background: var(--color-blue);
        color: white;
      }
    }
  }

  @media (max-width: 767px) {
    .contact {
      &__grid {
        grid-template-columns: 1fr;
      }

      &__action {
        justify-content: flex-start;
      }

      &__button {
        min-width: min(100%, 292px);
      }
    }
  }
</style>
