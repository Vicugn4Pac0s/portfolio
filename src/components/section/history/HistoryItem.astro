---
interface Props {
  title: string;
  text: string;
}

const { title, text } = Astro.props;
---

<article class="history-item">
  <details class="history-item__details">
    <summary class="history-item__summary">
      <h3 class="history-item__title">{title}</h3>
      <p class="history-item__text">{text}</p>
    </summary>
    <div class="history-item__detail">詳細が入ります</div>
  </details>
</article>

<script>
  class HistoryItemAccordion {
    private animation: Animation | null = null;
    private isClosing = false;
    private isExpanding = false;
    private readonly details: HTMLDetailsElement;
    private readonly summary: HTMLElement;
    private readonly content: HTMLElement;

    constructor(root: HTMLElement) {
      const details = root.querySelector<HTMLDetailsElement>('.history-item__details');
      const summary = root.querySelector<HTMLElement>('.history-item__summary');
      const content = root.querySelector<HTMLElement>('.history-item__detail');

      if (!details || !summary || !content) {
        throw new Error('History item elements are missing.');
      }

      this.details = details;
      this.summary = summary;
      this.content = content;

      this.summary.addEventListener('click', (event) => this.handleClick(event));
    }

    private handleClick(event: MouseEvent) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        return;
      }

      event.preventDefault();
      this.details.style.overflow = 'hidden';

      if (this.isClosing || !this.details.open) {
        this.open();
        return;
      }

      this.shrink();
    }

    private shrink() {
      this.isClosing = true;

      const startHeight = `${this.details.offsetHeight}px`;
      const endHeight = `${this.summary.offsetHeight}px`;

      this.animation?.cancel();
      this.animation = this.details.animate(
        {
          height: [startHeight, endHeight],
        },
        {
          duration: 240,
          easing: 'ease-out',
        },
      );

      this.animation.onfinish = () => this.finishAnimation(false);
      this.animation.oncancel = () => {
        this.isClosing = false;
      };
    }

    private open() {
      this.details.style.height = `${this.details.offsetHeight}px`;
      this.details.open = true;

      requestAnimationFrame(() => this.expand());
    }

    private expand() {
      this.isExpanding = true;

      const startHeight = `${this.details.offsetHeight}px`;
      const endHeight = `${this.summary.offsetHeight + this.content.scrollHeight}px`;

      this.animation?.cancel();
      this.animation = this.details.animate(
        {
          height: [startHeight, endHeight],
        },
        {
          duration: 280,
          easing: 'ease-out',
        },
      );

      this.animation.onfinish = () => this.finishAnimation(true);
      this.animation.oncancel = () => {
        this.isExpanding = false;
      };
    }

    private finishAnimation(open: boolean) {
      this.details.open = open;
      this.animation = null;
      this.isClosing = false;
      this.isExpanding = false;
      this.details.style.height = '';
      this.details.style.overflow = '';
    }
  }

  document.querySelectorAll<HTMLElement>('.history-item').forEach((root) => {
    if (root.dataset.accordionInitialized === 'true') {
      return;
    }

    root.dataset.accordionInitialized = 'true';
    new HistoryItemAccordion(root);
  });
</script>

<style lang="scss">
  .history-item {
    position: relative;

    &::before {
      position: absolute;
      top: 6px;
      left: -55px;
      width: 12px;
      height: 12px;
      border-radius: 999px;
      background: var(--color-blue);
      content: "";
    }

    &__details {
      margin: 0;
      padding: 0;
    }

    &__summary {
      appearance: none;
      margin: 0;
      padding: 0;
      cursor: pointer;
      list-style: none;
      list-style-type: none;

      &::marker,
      &::-webkit-details-marker {
        display: none;
        content: "";
      }
    }

    &__title {
      margin: 0 0 10px;
      font-size: 15px;
      font-weight: 800;
    }

    &__text {
      margin: 0;
      color: var(--color-muted);
      font-size: 14px;
      font-weight: 650;
      line-height: 2;
    }
    &__detail {
      font-size: 14px;
      padding: 12px 12px 0;
    }
  }

  @media (max-width: 767px) {
    .history-item {
      &::before {
        left: -41px;
      }
    }
  }
</style>
