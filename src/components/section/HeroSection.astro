---
---

<section
  class="hero"
>
  <div class="hero__inner site-container">
    <div class="hero__content">
      <p class="hero__subtitle">FRONTEND ENGINEER × RUNNER</p>
      <h1 class="hero__title">
        YOSHIKI YAMADA
      </h1>
      <p class="hero__lead">
        テキストが入ります。テキストが入ります。
      </p>
    </div>
    <div class="hero__image">
      <img src="/images/hero-img.webp" alt="" />
      <p class="hero__image-caption">テキストが入ります。テキストが入ります。</p>
    </div>
    <div class="hero__bg-particle hero__bg-particle--1"></div>
    <div class="hero__bg-particle hero__bg-particle--2"></div>
  </div>
</section>

<style lang="scss">
  .hero {
    padding-top: 80px;
    overflow: hidden;

    &__inner {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      min-height: 680px;
    }

    &__content {
      position: relative;
      z-index: 1;
    }

    &__title {
      margin: 0;
      color: var(--color-ink);
      font-size: 6.4rem;
      font-weight: 700;
      margin-bottom: 2.4rem;
    }
    
    &__subtitle {
      font-size: 2.4rem;
    }
    &__lead {
      line-height: 1.8;
    }

    &__image {
      position: absolute;
      top: 50%;
      right: 4rem;
      transform: translateY(-50%);
      width: 38rem;

      img {
        height: auto;
        width: 100%;
        vertical-align: middle;
      }
    }

    &__image-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      transform: translateX(-100%);
      font-size: 1.4rem;
    }

    &__bg-particle {
      position: absolute;
      top: 50%;
      transform: translateY(-50%) rotate(45deg);      
      z-index: 0;

      &--1 {
        background: var(--color-primary);
        height: 2800px;
        width: 900px;
        left: -650px;
        opacity: 0.1;
      }

      &--2 {
        background: var(--color-accent);
        height: 1200px;
        width: 90px;
        right: -285px;
        opacity: 0.5;
      }
    }
  }

  @media (max-width: 767px) {
    .hero {
      min-height: 560px;
      background-position: 65% center;

      &__inner {
        min-height: 560px;
      }

      &__title {
        font-size: 34px;
      }

      &__lead {
        font-size: 15px;
      }
    }
  }
</style>
