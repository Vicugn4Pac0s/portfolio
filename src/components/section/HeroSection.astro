---
---

<section
  class="hero"
>
  <div class="hero__inner site-container">
    <div class="hero__content">
      <p class="hero__subtitle">FRONTEND ENGINEER × RUNNER</p>
      <h1 class="hero__title">
        YOSHIKI YAMADA
      </h1>
      <p class="hero__lead">
        走って整えるエンジニア。<br>日々の積み重ねで身体と技術を磨き、<br>制作と開発の現場を、フロントエンドから支えます。
      </p>
    </div>
    <div class="hero__image">
      <img src="/images/hero-img.webp" alt="" />
      <p class="hero__image-caption">テキストが入ります。テキストが入ります。</p>
    </div>
    <div class="hero__bg-particle hero__bg-particle--1"></div>
    <div class="hero__bg-particle hero__bg-particle--2"></div>
  </div>
</section>

<style lang="scss">
  @use '@styles/global' as *;

  .hero {
    padding-top: 80px;
    overflow: hidden;

    &__inner {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      min-height: 680px;

      @include media-tab {
        min-height: 620px;
      }

      @include media-sp {
        min-height: 560px;
      }
    }

    &__content {
      position: relative;
      z-index: 1;

      @include media-sp {
        padding-top: 24rem;
      }
    }

    &__title {
      margin: 0;
      color: var(--color-ink);
      font-size: 6.4rem;
      font-style: italic;
      font-weight: 600;
      margin-bottom: 2.4rem;

      @include media-tab {
        font-size: 4.8rem;
      }

      @include media-sp {
        font-size: 3.2rem;
        margin-bottom: 1.6rem;
      }
    }
    
    &__subtitle {
      font-size: 2.4rem;
      font-weight: 200;
      font-style: italic;

      @include media-tab {
        font-size: 2.0rem;
      }

      @include media-sp {
        font-size: 1.6rem;
      }
    }
    &__lead {
      line-height: 1.8;

      @include media-sp {
        font-size: 1.4rem;
      }
    }

    &__image {
      position: absolute;
      top: 50%;
      right: 4rem;
      transform: translateY(-50%);
      width: 38rem;

      @include media-tab {
        width: 26rem;
        right: 2rem;
      }

      @include media-sp {
        width: 20rem;
        top: 0;
        right: 0;
        transform: translateY(0);
      }

      img {
        height: auto;
        width: 100%;
        vertical-align: middle;
      }
    }

    &__image-caption {
      position: absolute;
      bottom: 0;
      left: 0;
      transform: translateX(-105%);
      font-size: 1.2rem;

      @include media-sp {
        font-size: 1rem;
        bottom: auto;
        top: 0;
        width: 14rem;
      }
    }

    &__bg-particle {
      position: absolute;
      top: 50%;
      transform: translateY(-50%) rotate(45deg);      
      z-index: 0;

      &--1 {
        background: var(--color-primary);
        height: 2800px;
        width: 900px;
        left: -650px;
        opacity: 0.1;

        @include media-sp {
          height: 1600px;
          width: 280px;
          left: -440px;
        }
      }

      &--2 {
        background: var(--color-accent);
        height: 1200px;
        width: 90px;
        right: -288px;
        opacity: 0.5;

        @include media-sp {
          height: 1000px;
          width: 40px;
          right: -240px;
        }
      }
    }

    // ── OPアニメーション初期状態 ──
    &__bg-particle--1,
    &__bg-particle--2,
    &__subtitle,
    &__title,
    &__lead,
    &__image {
      opacity: 0;
    }

    @media (prefers-reduced-motion: reduce) {
      &__bg-particle--1 { opacity: 0.1; }
      &__bg-particle--2 { opacity: 0.5; }

      &__subtitle,
      &__title,
      &__lead,
      &__image {
        opacity: 1;
      }
    }
  }
</style>

<script>
  import gsap from 'gsap';

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const hero = document.querySelector('.hero');
    const p1   = hero?.querySelector<HTMLElement>('.hero__bg-particle--1');
    const p2   = hero?.querySelector<HTMLElement>('.hero__bg-particle--2');
    const sub  = hero?.querySelector<HTMLElement>('.hero__subtitle');
    const ttl  = hero?.querySelector<HTMLElement>('.hero__title');
    const lead = hero?.querySelector<HTMLElement>('.hero__lead');
    const img  = hero?.querySelector<HTMLElement>('.hero__image');

    if (p1 && p2 && sub && ttl && lead && img) {
      // CSS transform を GSAP に引き渡す（rotate・yPercent を維持したまま x だけ動かす）
      gsap.set(p1, { x: -1600, yPercent: -50, rotation: 45, filter: 'blur(8px)'  });
      gsap.set(p2, { x:  1600, yPercent: -50, rotation: 45, filter: 'blur(12px)' });

      // 写真は PC/SP で translateY が異なるため breakpoint を見て yPercent を設定
      const isSp = window.matchMedia('(max-width: 767px)').matches;
      gsap.set(img, { x: 64, yPercent: isSp ? 0 : -50, opacity: 0, skewX: -2 });

      gsap.timeline()
        // ① スピードライン：左右から高速スライドイン＋モーションブラー
        .to(p1, { x: 0, opacity: 0.1, filter: 'blur(0px)', duration: 0.55, ease: 'power4.out' })
        .to(p2, { x: 0, opacity: 0.5, filter: 'blur(0px)', duration: 0.45, ease: 'power4.out' }, '<0.08')
        // ② テキスト：右からシュッ（スキュー＋モーションブラー）
        .fromTo(sub,
          { opacity: 0, x: 32, skewX: -12,  filter: 'blur(4px)' },
          { opacity: 1, x: 0,  skewX: 0,   filter: 'blur(0px)', duration: 0.5,  ease: 'power3.out' },
          0.35
        )
        .fromTo(ttl,
          { opacity: 0, x: 48, skewX: -6, filter: 'blur(6px)' },
          { opacity: 1, x: 0,  skewX: 0,   filter: 'blur(0px)', duration: 0.55, ease: 'power3.out' },
          0.48
        )
        .fromTo(lead,
          { opacity: 0, x: 24, skewX: -4,  filter: 'blur(3px)' },
          { opacity: 1, x: 0,  skewX: 0,   filter: 'blur(0px)', duration: 0.5,  ease: 'power3.out' },
          0.64
        )
        // ③ 写真：右からシュッ（スキュー）
        .to(img, { x: 0, opacity: 1, skewX: 0, duration: 0.7, ease: 'power3.out' }, 0.4);
    }
  }
</script>
